# Required
DATABASE_URL=postgresql://postgres:password@localhost:5432/distributed_job_platform

# Optional
PORT=3000
REDIS_URL=redis://localhost:6379

# Worker tuning
# How many jobs can run in parallel inside one worker process (default: 5)
# Do not set higher than your DB pool max (currently 10)
WORKER_CONCURRENCY=5
# How often (ms) the worker polls the DB for new jobs when idle (default: 2000)
POLL_INTERVAL_MS=2000